
# KONTACT VO - Environment Variables Example
# Copy this file to .env and fill in your actual values

# =================================
# SUPABASE CONFIGURATION
# =================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =================================
# APPLICATION CONFIGURATION
# =================================
# Application environment (development, staging, production)
VITE_APP_ENV=development

# Application URL (used for redirects and links)
VITE_APP_URL=http://localhost:8080

# Default language for the application
VITE_DEFAULT_LANGUAGE=es

# =================================
# AUTHENTICATION SETTINGS
# =================================
# JWT Secret (for local development only)
VITE_JWT_SECRET=your-jwt-secret-key

# Session timeout in minutes
VITE_SESSION_TIMEOUT=1440

# =================================
# FILE UPLOAD CONFIGURATION
# =================================
# Maximum file size in MB for image uploads
VITE_MAX_IMAGE_SIZE=10

# Maximum file size in MB for document uploads
VITE_MAX_DOCUMENT_SIZE=50

# Allowed image file types (comma-separated)
VITE_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# Allowed document file types (comma-separated)
VITE_ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xls,xlsx

# =================================
# TRANSLATION SERVICES
# =================================
# Google Translate API Key (optional, for automatic translations)
VITE_GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# =================================
# EMAIL CONFIGURATION
# =================================
# SMTP settings for email notifications (configured in Supabase)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your-email@gmail.com
VITE_SMTP_PASS=your-app-password

# From email address for system notifications
VITE_FROM_EMAIL=noreply@kontactvo.com

# =================================
# ANALYTICS & MONITORING
# =================================
# Google Analytics ID (optional)
VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=https://your-sentry-dsn

# Enable debug mode
VITE_DEBUG=false

# =================================
# THIRD-PARTY INTEGRATIONS
# =================================
# Google Maps API Key (for location features)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe API Keys (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# =================================
# RATE LIMITING
# =================================
# API rate limit per minute per user
VITE_API_RATE_LIMIT=100

# Upload rate limit per hour per user
VITE_UPLOAD_RATE_LIMIT=50

# =================================
# CACHE CONFIGURATION
# =================================
# Redis URL for caching (optional, for production)
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
VITE_CACHE_TTL=3600

# =================================
# SECURITY SETTINGS
# =================================
# CORS allowed origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Content Security Policy mode (report-only, enforce)
VITE_CSP_MODE=report-only

# =================================
# BUSINESS LOGIC CONFIGURATION
# =================================
# Default commission percentage for transactions
VITE_DEFAULT_COMMISSION_RATE=3.5

# Minimum bid increment for auctions
VITE_MIN_BID_INCREMENT=50

# Maximum auction duration in days
VITE_MAX_AUCTION_DURATION=30

# Currency for calculations
VITE_DEFAULT_CURRENCY=EUR

# =================================
# DEVELOPMENT ONLY
# =================================
# Show debug information in UI
VITE_SHOW_DEBUG_INFO=false

# Enable development tools
VITE_ENABLE_DEV_TOOLS=true

# Mock external services (for testing)
VITE_MOCK_SERVICES=false

# =================================
# BACKUP & MAINTENANCE
# =================================
# Maintenance mode message
VITE_MAINTENANCE_MESSAGE="Scheduled maintenance in progress"

# Backup frequency in hours
VITE_BACKUP_FREQUENCY=24

# Data retention period in days
VITE_DATA_RETENTION_DAYS=365
